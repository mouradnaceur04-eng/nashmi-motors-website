{
  "outputDirectory": ".",
  "functions": {
    "api/inventory.js": {
      "maxDuration": 15,
      "includeFiles": "public/inventory.json"
    }
  },
  "headers": [
    {
      "source": "/inventory.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/inventory",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, stale-while-revalidate=30" }
      ]
    }
  ]
}
